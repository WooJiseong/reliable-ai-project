{
  "model": {
    "name": "conformer_ctc",
    "size": "small",
    "sample_rate": 16000,
    "n_mels": 80,
    "ctc": true
  },
  "attack": {
    "name": "pgd",
    "steps": 5,
    "epsilon": 0.005,
    "alpha": 0.001,
    "norm": "linf",
    "objective": "maximize_ctc_loss",
    "random_start": false
  },
  "evaluation": {
    "languages": ["ko", "en", "zh", "ru"],
    "metrics": ["wer", "cer"],
    "degradation": "attacked_metric - clean_metric",
    "robustness_gap": "max(language_degradation) - min(language_degradation)"
  }
}
